{
  "name": "flatpak-bun-generator",
  "version": "1.0.1",
  "description": "Generate Flatpak sources from bun.lock files",
  "repository": "https://github.com/MultiboxLabs/flatpak-bun-generator",
  "homepage": "https://github.com/MultiboxLabs/flatpak-bun-generator#readme",
  "keywords": [
    "flatpak",
    "bun",
    "generator"
  ],
  "bin": {
    "flatpak-bun-generator": "dist/main.js"
  },
  "engines": {
    "bun": ">=1.0.0"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.build.json",
    "generate": "bun run .",
    "prepublishOnly": "bun run build",
    "test": "bun test"
  },
  "license": "MIT",
  "publishConfig": {
    "provenance": true,
    "access": "public"
  },
  "devDependencies": {
    "@types/bun": "latest"
  },
  "main": "./dist/main.js",
  "module": "./dist/main.js",
  "exports": "./dist/main.js",
  "type": "module",
  "peerDependencies": {
    "typescript": "^5"
  }
}
